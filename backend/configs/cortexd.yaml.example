# Cortex Daemon Configuration
# Copy this file to cortexd.local.yaml and customize as needed.
# cortexd.local.yaml is gitignored.

# Server settings
grpc_address: "localhost:50051"
http_address: "localhost:8080"

# Storage settings
data_dir: "./cortex-data"
plugin_dir: "./cortex-data/plugins"

# Worker settings
worker_count: 4
max_concurrent_tasks: 10

# Logging
log_level: "info"  # debug, info, warn, error
# log_file: /var/log/cortex/cortexd.log

# Mirror extraction (text from PDFs, Office docs)
mirror:
  max_file_size_mb: 25

# Directories to index and watch for changes
watch_paths:
  - "/path/to/your/workspace"

# LLM settings (all AI features enabled by default)
llm:
  enabled: true
  default_provider: "ollama"
  default_model: "llama3.2"
  max_context_tokens: 2000
  request_timeout_ms: 30000

  # Auto-generate summaries for indexed files
  auto_summary:
    enabled: true
    max_file_size: 250000  # bytes, 0 = no limit

  # Auto-generate tags and project suggestions
  auto_index:
    enabled: true
    apply_tags: true
    apply_projects: true
    use_suggested_contexts: true
    max_file_size: 250000
    max_tags: 5
    enable_categories: true
    enable_related: true
    max_related_results: 10
    related_candidates: 100
    # Use RAG to improve AI suggestions
    use_rag_for_categories: true
    use_rag_for_tags: true
    use_rag_for_projects: true
    use_rag_for_related: true
    use_rag_for_summary: true
    rag_similarity_threshold: 0.5  # 0.0-1.0

  # Embedding model for RAG / semantic search
  embeddings:
    enabled: true
    endpoint: "http://localhost:11434"
    model: "nomic-embed-text"

  # LLM providers
  providers:
    - id: "ollama"
      type: "ollama"
      endpoint: "http://localhost:11434"

    - id: "lmstudio"
      type: "openai"
      endpoint: "http://localhost:1234/v1"

    # Uncomment to use OpenAI API
    # - id: "openai"
    #   type: "openai"
    #   endpoint: "https://api.openai.com/v1"
    #   api_key: "${OPENAI_API_KEY}"

    # Uncomment to use Anthropic API
    # - id: "anthropic"
    #   type: "anthropic"
    #   endpoint: "https://api.anthropic.com"
    #   api_key: "${ANTHROPIC_API_KEY}"

# Apache Tika (document metadata extraction)
# Requires Java if manage_process is true
tika:
  enabled: false
  manage_process: true
  auto_download: true
  endpoint: "http://localhost:9998"
  port: 9998
  timeout: 30s
  max_file_size: 104857600  # 100 MB
